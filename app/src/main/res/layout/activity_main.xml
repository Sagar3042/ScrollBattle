<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F0F"
    android:padding="20dp">

    <!-- Header Section -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Leaderboard"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_centerVertical="true"/>

        <!-- 3-Line Menu Icon (☰) -->
        <TextView
            android:id="@+id/btn_menu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☰" 
            android:textColor="#FFFFFF"
            android:textSize="35sp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"/>
    </RelativeLayout>

    <!-- Leaderboard List Area (এখানে পরে ইউজারদের র‍্যাংক বসবে) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:layout_above="@id/btn_start_battle"
        android:layout_marginBottom="20dp">
        
        <LinearLayout
            android:id="@+id/leaderboard_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <!-- ফায়ারবেস থেকে ডেটা এনে এখানে দেখানো হবে -->
        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btn_start_battle"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_alignParentBottom="true"
        android:text="Start Battle &amp; Open Instagram"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#E1306C"
        android:textColor="#FFFFFF"/>

</RelativeLayout>
