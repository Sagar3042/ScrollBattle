<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F0F"
    android:padding="20dp">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Scroll Battle Profile"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"/>

    <!-- Profile Section (Glassmorphism Card) -->
    <LinearLayout
        android:id="@+id/profile_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tv_title"
        android:background="@drawable/glass_card"
        android:orientation="vertical"
        android:padding="20dp"
        android:elevation="10dp">

        <EditText
            android:id="@+id/et_first_name"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="First Name"
            android:textColorHint="#888888"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/et_last_name"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Last Name"
            android:textColorHint="#888888"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/et_insta"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Instagram Username"
            android:textColorHint="#888888"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btn_save_profile"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Save Profile"
            android:backgroundTint="#E1306C"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <!-- Start Battle Button (এই বাটনের জন্যই এরর আসছিল) -->
    <Button
        android:id="@+id/btn_start_battle"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_below="@id/profile_card"
        android:layout_marginTop="40dp"
        android:text="Start Battle &amp; Open Instagram"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#FFFFFF"
        android:textColor="#000000"/>

</RelativeLayout>

